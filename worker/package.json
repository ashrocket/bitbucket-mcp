{
  "name": "bitbucket-mcp-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted Bitbucket MCP — Cloudflare Worker with OAuth, Stripe donations, D1 persistence.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "d1:create": "wrangler d1 create bitbucket-mcp-prod",
    "d1:apply-local": "wrangler d1 execute bitbucket-mcp-prod --local --file=schema.sql",
    "d1:apply-prod": "wrangler d1 execute bitbucket-mcp-prod --remote --file=schema.sql"
  },
  "dependencies": {
    "@ashrocket/bitbucket-mcp-core": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
