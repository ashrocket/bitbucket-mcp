# ─────────────────────────────────────────────────────────────
# Bitbucket MCP Server — Auth (pick ONE method)
# ─────────────────────────────────────────────────────────────

# Method 1 (recommended): Atlassian API Token
# Generate at https://id.atlassian.com/manage-profile/security/api-tokens
# The server accepts either your Atlassian email OR the special username
# `x-bitbucket-api-token-auth` (the special username is more reliable).
BITBUCKET_API_TOKEN=
BITBUCKET_USERNAME=           # optional — defaults to x-bitbucket-api-token-auth

# Method 2: Workspace / Repository / Project Access Token (Bearer)
# Generate in Bitbucket workspace/repo settings → Access tokens
# If set, takes precedence over API_TOKEN.
BITBUCKET_ACCESS_TOKEN=

# Method 3 (legacy, deprecated Sep 2025): App Password
# https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_APP_PASSWORD=

# Optional: default workspace slug (so tool calls can omit it)
BITBUCKET_WORKSPACE=

# ─────────────────────────────────────────────────────────────
# Site — public vars (safe to expose)
# ─────────────────────────────────────────────────────────────
PUBLIC_DONATION_URL=https://donate.stripe.com/placeholder-replace-me
PUBLIC_WORKER_URL=https://bitbucket-mcp-api.ashrocket.workers.dev
PUBLIC_GITHUB_REPO=https://github.com/ashrocket/bitbucket-mcp

# ─────────────────────────────────────────────────────────────
# Worker — secrets (set via `wrangler secret put`, NOT here)
# ─────────────────────────────────────────────────────────────
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_RESTRICTED_KEY=rk_...
