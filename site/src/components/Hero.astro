---
import { config } from '../lib/config';
import { totalToolCount } from '../lib/tools';
---

<section class="hero">
  <div class="shell hero-inner">
    <div class="badge">MCP · open source · MIT</div>
    <h1>
      Bitbucket, from Claude.<br />
      <span class="accent">Free. Donation-supported.</span>
    </h1>
    <p class="lede">
      A zero-config Model Context Protocol server for Bitbucket Cloud — {totalToolCount} tools
      covering pull requests, pipelines, issues, and everything else you'd open the Bitbucket UI for.
      Works in Claude Desktop, Claude Code, Codex, Cursor, and any MCP client.
    </p>
    <div class="cta-row">
      <a class="btn" href={config.donationUrl} rel="noopener noreferrer">Donate →</a>
      <a class="btn btn-ghost" href="#install">Install in 30 seconds</a>
      <a class="btn btn-ghost" href={config.githubRepo} rel="noopener noreferrer">View source</a>
    </div>
    <p class="sub">
      100% of donations pay for maintenance, new tools, and support.
      <a href="#ads">No tracking, no lock-in, no upsell.</a>
    </p>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 5rem;
    background:
      radial-gradient(circle at 10% 0%, var(--accent-soft) 0%, transparent 50%),
      radial-gradient(circle at 100% 30%, rgba(0, 82, 204, 0.08) 0%, transparent 40%),
      var(--bg);
    border-bottom: 1px solid var(--rule);
  }
  .badge {
    display: inline-block;
    padding: 4px 12px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
  .accent { color: var(--accent-ink); }
  .lede {
    font-size: 1.2rem;
    max-width: 680px;
    color: var(--ink-muted);
    margin: 1.25rem 0 2rem;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .sub {
    color: var(--ink-faint);
    font-size: 0.95rem;
    margin-top: 2.5rem;
  }
</style>
