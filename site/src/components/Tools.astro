---
import { toolGroups, totalToolCount } from '../lib/tools';
---

<section id="tools">
  <div class="shell">
    <div class="kicker">Tools · v1</div>
    <h2>{totalToolCount} tools for daily use.</h2>
    <p class="lede">
      Focused on the 80/20 of PR review and CI triage. The full 53-tool set
      ships in the local stdio package for power users. Feature requests welcome —
      file an issue.
    </p>

    <div class="groups">
      {toolGroups.map((group) => (
        <article class="group" id={`group-${group.slug}`}>
          <header>
            <h3>{group.title}</h3>
            <span class="count">{group.tools.length}</span>
          </header>
          <p class="blurb">{group.blurb}</p>
          <ul>
            {group.tools.map((name) => <li><code>{name}</code></li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .lede {
    color: var(--ink-muted);
    max-width: 60ch;
    margin: 0.5rem 0 2rem;
  }
  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  .group {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .group header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
  }
  .group h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--ink);
  }
  .count {
    background: var(--accent-soft);
    color: var(--accent-ink);
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .blurb {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.9rem;
  }
  .group ul {
    list-style: none;
    margin: 0.2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .group ul li {
    font-size: 0.82rem;
    color: var(--ink-muted);
  }
  .group ul li code {
    background: transparent;
    color: var(--ink-muted);
    padding: 0;
  }
</style>
